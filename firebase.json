      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "old_versions/**",
      "docs/**",
      "*.md",
      "*.py"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}